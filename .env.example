# Airtable Integration
# Get your personal access token from https://airtable.com/account
AIRTABLE_API_KEY=your_personal_access_token_here

# Found in your Airtable base's API documentation page (starts with "app")
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Auth (NextAuth v5)
# Run: openssl rand -base64 32
AUTH_SECRET=your_32_char_random_string_here

# Separate secret for JWT password-reset tokens
# Run: openssl rand -base64 32
RESET_TOKEN_SECRET=your_32_char_random_string_here

# n8n webhook URL — receives { email, name, resetLink } and sends the reset email
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/xxxxx

# Full app URL — used to build reset links (no trailing slash)
APP_URL=http://localhost:3000

# V1 only — remove when Slice 7 is complete
DEFAULT_USER_ID=recXXXXXXXXXXXXXX
