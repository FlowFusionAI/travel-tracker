# Airtable Integration
# Get your personal access token from https://airtable.com/account
AIRTABLE_API_KEY=your_personal_access_token_here

# Found in your Airtable base's API documentation page (starts with "app")
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# V1 only: Airtable record ID for the single admin user (starts with "rec")
# Replace with your actual Users table record ID after creating your user record.
# Removed in V2 when NextAuth ships.
DEFAULT_USER_ID=recXXXXXXXXXXXXXX

# V2 only — fill these in when adding NextAuth (Slice 7)
# NEXTAUTH_SECRET=run: openssl rand -base64 32
# NEXTAUTH_URL=https://your-app.vercel.app
# GOOGLE_CLIENT_ID=from Google Cloud Console OAuth credentials
# GOOGLE_CLIENT_SECRET=from Google Cloud Console OAuth credentials
